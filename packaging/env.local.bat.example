@echo off
REM Copy this file to env.local.bat (same folder) and fill in real values.
REM env.local.bat is gitignored so your secrets never get committed.

REM From Google Cloud Console -> Credentials -> OAuth client ID (Web application)
set GIS_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

REM A long random string used to sign session cookies. Generate one, e.g.:
REM   python -c "import secrets; print(secrets.token_urlsafe(48))"
set GIS_SESSION_SECRET=replace-with-a-long-random-string
