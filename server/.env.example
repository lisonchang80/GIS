# Copy to server/.env and fill in. These are read as environment variables;
# .env is NOT auto-loaded — export them before running uvicorn (see README).

# From Google Cloud Console -> Credentials -> OAuth client ID (Web application)
GIS_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Long random string used to sign session cookies. Change it.
GIS_SESSION_SECRET=change-me-to-a-long-random-string

# 1 in production (HTTPS via tunnel). Set 0 for plain-http localhost testing.
GIS_COOKIE_SECURE=1

# Comma-separated extra origins allowed to call the API with credentials.
GIS_CORS_ORIGINS=http://localhost:5173

# Local testing only: enables POST /api/auth/dev-login (fake user, no Google).
GIS_DEV_LOGIN=0
